# Enforce consistent line endings across Windows/WSL/Linux.
# All text files are normalized to LF in the repository
# and checked out as LF regardless of platform.

* text=auto eol=lf

# Windows-specific scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.pdf binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.svg binary
